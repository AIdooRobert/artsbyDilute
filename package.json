{
  "name": "snapfolio-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run typecheck && npm run test && npm run security:audit && npm run build",
    "admin:create": "node --env-file=.env.local scripts/create-admin.mjs",
    "legacy:migrate": "node --env-file=.env.local scripts/migrate-legacy.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.107.0",
    "jszip": "^3.10.1",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.7",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
